# Database
# For PostgreSQL (Production/Docker): DATABASE_URL="postgresql://user:password@localhost:5432/elahe"
# For SQLite (Local Dev only):         DATABASE_URL="file:./prisma/dev.db"
#
# NOTE: If DATABASE_URL is not set in development, the app automatically falls back to SQLite.
# In production, DATABASE_URL must be set to a valid PostgreSQL connection string.
DATABASE_URL="postgresql://__DB_USER__:__DB_PASSWORD__@__DB_HOST__:5432/__DB_NAME__"
PRISMA_CONNECTION_LIMIT=10

# App
APP_URL="http://localhost:3000"
APP_ENV="development"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
CDN_URL=""
LOG_LEVEL="info"
CACHE_TTL_MS=30000

# Security
JWT_SECRET="__CHANGE_ME_JWT_SECRET_MIN_32_CHARS__"
SESSION_SECRET="__CHANGE_ME_SESSION_SECRET_MIN_32_CHARS__"
ENCRYPTION_KEY="__CHANGE_ME_ENCRYPTION_KEY_MIN_32_CHARS__"
ADMIN_USERNAME="__SET_ME_ADMIN_USERNAME__"
ADMIN_PASSWORD="__CHANGE_ME_ADMIN_PASSWORD_MIN_16_CHARS__"
VAPID_PUBLIC_KEY="__OPTIONAL_VAPID_PUBLIC_KEY__"
VAPID_PRIVATE_KEY="__OPTIONAL_VAPID_PRIVATE_KEY__"
VAPID_EMAIL="mailto:admin@example.com"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Backups
BACKUP_OUTPUT_DIR="./backups"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_MAX=30

# Redis / Scaling
REDIS_URL="redis://localhost:6379"

# Queueing
QUEUE_CONCURRENCY=5

# Firebase (Client-side)
NEXT_PUBLIC_FIREBASE_API_KEY="__OPTIONAL_FIREBASE_API_KEY__"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="__OPTIONAL_FIREBASE_AUTH_DOMAIN__"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="__OPTIONAL_FIREBASE_PROJECT_ID__"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="__OPTIONAL_FIREBASE_STORAGE_BUCKET__"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="__OPTIONAL_FIREBASE_MESSAGING_SENDER_ID__"
NEXT_PUBLIC_FIREBASE_APP_ID="__OPTIONAL_FIREBASE_APP_ID__"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="__OPTIONAL_FIREBASE_VAPID_KEY__"
