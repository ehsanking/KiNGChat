{
  "name": "elahe-messenger",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-server.mjs",
    "build": "next build",
    "start": "node scripts/start-server.mjs --production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node scripts/clean.mjs",
    "backup": "tsx scripts/backup.ts",
    "db:setup": "npm run db:init:dev",
    "db:init:dev": "tsx scripts/db-setup.ts init-dev",
    "db:migrate:prod": "tsx scripts/db-setup.ts migrate-prod",
    "prisma:generate": "tsx scripts/prisma-generate.ts",
    "validate:env": "tsx scripts/validate-env.ts",
    "postinstall": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/client": "5.22.0",
    "@prisma/instrumentation": "^7.7.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@tanstack/react-virtual": "^3.13.23",
    "argon2": "0.41.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "idb": "8.0.3",
    "lucide-react": "0.553.0",
    "motion": "12.38.0",
    "next": "15.5.14",
    "otpauth": "9.5.0",
    "pino": "^9.14.0",
    "postcss": "8.5.8",
    "prisma": "5.22.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "4.7.1",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tailwind-merge": "3.5.0",
    "tsx": "4.21.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "10.4.27",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.5.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "4.1.11",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "glob": "^11.0.2",
    "rimraf": "^6.0.1",
    "fraction.js": "5.3.4",
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.0.3"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "license": "MIT"
}
