{
  "name": "elahe-messenger",
  "version": "1.0.0",
  "description": "Elahe Messenger — production messaging platform (Next.js 15 + React 19 + Prisma 6 + Socket.IO).",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-server.mjs",
    "build": "next build",
    "start": "node scripts/start-server.mjs --production",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "node scripts/clean.mjs",
    "backup": "tsx scripts/backup.ts",
    "db:setup": "npm run db:init:dev",
    "db:init:dev": "tsx scripts/db-setup.ts init-dev",
    "db:migrate:prod": "tsx scripts/db-setup.ts migrate-prod",
    "prisma:generate": "tsx scripts/prisma-generate.ts",
    "validate:env": "tsx scripts/validate-env.ts",
    "postinstall": "npm run prisma:generate",
    "prebuild": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/client": "^6.19.3",
    "@prisma/instrumentation": "^6.19.3",
    "@socket.io/redis-adapter": "8.3.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@node-rs/argon2": "^1.7.0",
    "bullmq": "^5.73.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "geist": "^1.7.0",
    "idb": "8.0.3",
    "ioredis": "^5.10.1",
    "lucide-react": "0.553.0",
    "motion": "12.38.0",
    "next": "15.5.15",
    "node-cron": "^4.2.1",
    "otpauth": "9.5.0",
    "pino": "^9.14.0",
    "postcss": "8.5.8",
    "prisma": "^6.19.3",
    "qrcode": "1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "redis": "4.7.1",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "tailwind-merge": "3.5.0",
    "tsx": "4.21.0",
    "web-push": "3.6.7",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-webpack-plugin": "^7.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "10.4.27",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.5.15",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "glob": "^11.0.2",
    "rimraf": "^6.0.1",
    "fraction.js": "5.3.4",
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.0.3",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "license": "MIT"
}
